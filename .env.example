# Transport mode: "stdio" (local) or "http" (cloud/VPS)
TRANSPORT=http

# Port for HTTP mode (nginx will proxy to this)
PORT=3200

# Default active connection (must match a key in connections.json)
DEFAULT_DB=knowledge

# Bearer token for HTTP auth — set a strong random value
# Generate with: openssl rand -hex 32
MCP_TOKEN=change_me_to_a_strong_secret

# Optional: custom path to connections.json
# CONNECTIONS_FILE=/opt/PostgresMCP/connections.json
